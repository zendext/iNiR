#!/usr/bin/env bash
set -euo pipefail

qs_bin="/usr/bin/qs"
user_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/inir"
system_config_dir="${INIR_SYSTEM_RUNTIME_DIR:-/usr/local/share/quickshell/inir}"
fallback_system_config_dir="${INIR_FALLBACK_SYSTEM_RUNTIME_DIR:-/usr/share/quickshell/inir}"
config_dir="${INIR_RUNTIME_DIR:-}"
poll_delay="${INIR_RESTART_POLL_DELAY:-0.1}"
max_polls="${INIR_RESTART_MAX_POLLS:-60}"
max_rapid_restarts="${INIR_MAX_RAPID_RESTARTS:-5}"
restart_window="${INIR_RESTART_WINDOW:-60}"
systemd_user_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
launcher_root="$(cd -- "$script_dir/.." 2>/dev/null && pwd || printf '%s' "$script_dir")"

source_config_path_helper() {
    local helper_candidates=(
        "$script_dir/lib/config-path.sh"
        "$launcher_root/share/quickshell/inir/scripts/lib/config-path.sh"
        "$user_config_dir/scripts/lib/config-path.sh"
        "$system_config_dir/scripts/lib/config-path.sh"
        "$fallback_system_config_dir/scripts/lib/config-path.sh"
    )

    local helper_path
    for helper_path in "${helper_candidates[@]}"; do
        if [[ -f "$helper_path" ]]; then
            # shellcheck source=/dev/null
            source "$helper_path"
            return
        fi
    done

    echo "Unable to locate config-path helper (scripts/lib/config-path.sh)." >&2
    exit 1
}

source_config_path_helper

_ipc_registry_loaded=false

source_ipc_registry() {
    if [[ "$_ipc_registry_loaded" == true ]]; then
        return
    fi

    local registry_candidates=(
        "$script_dir/lib/ipc-registry.sh"
        "$launcher_root/share/quickshell/inir/scripts/lib/ipc-registry.sh"
        "$user_config_dir/scripts/lib/ipc-registry.sh"
        "$system_config_dir/scripts/lib/ipc-registry.sh"
        "$fallback_system_config_dir/scripts/lib/ipc-registry.sh"
    )

    local registry_path
    for registry_path in "${registry_candidates[@]}"; do
        if [[ -f "$registry_path" ]]; then
            # shellcheck source=/dev/null
            source "$registry_path"
            _ipc_registry_loaded=true
            return
        fi
    done

    # Registry not found — not fatal, features degrade gracefully.
    return 1
}

usage() {
    cat <<'EOF'
Usage: inir <command> [options]

Quick start:
  inir run               Start the shell
  inir settings          Open settings
  inir welcome           Re-open the welcome wizard (first-run tour)
  inir restart           Restart the shell
  inir logs              View runtime logs
  inir status            Shell status info
  inir doctor            Health checks

EOF

    print_cli_context

    # Dynamic IPC target listing from registry
    if source_ipc_registry 2>/dev/null; then
        printf 'IPC targets (inir <target> <function>):\n'
        _usage_print_targets "  Shared:" "shared"
        _usage_print_targets "  ii panel family:" "ii"
        _usage_print_targets "  waffle panel family:" "waffle"
        printf '\n  Run '\''inir <target> --help'\'' for available functions.\n\n'
    else
        cat <<'EOF'
IPC targets (inir <target> <function>):
  Use 'inir <target> --help' for available functions.
  See docs/IPC.md for the full reference.

EOF
    fi

    cat <<'EOF'
Runtime:
  start, stop, run, restart, kill, terminal, browser, close-window, colorpicker

Maintenance (delegates to setup):
  install, reinstall, update, doctor, status, migrate, rollback, my-changes, uninstall
  config, info, backup, logs, setup

Other:
  version [--json]
  theme <list-targets|inspect|doctor|apply|scaffold> [args...]
  completions <bash|zsh|fish>
  service <install|uninstall|enable|disable|start|stop|restart|status|logs>
  repair, path, test-local, settings-window, waffle-settings-window
EOF
}

read_version_field() {
    local version_file="$1"
    local jq_expr="$2"
    local fallback_regex="$3"

    [[ -n "$version_file" && -f "$version_file" ]] || return 1

    if command -v jq >/dev/null 2>&1; then
        jq -r "${jq_expr} // empty" "$version_file" 2>/dev/null || true
        return 0
    fi

    sed -n "s/.*${fallback_regex}.*/\\1/p" "$version_file" 2>/dev/null | head -1
}

resolve_live_version_context() {
    local version_file="$1"
    local runtime_path="$2"

    local install_mode=""
    install_mode="$(read_version_field "$version_file" '.installMode // .install_mode' '"installMode"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    [[ -z "$install_mode" ]] && install_mode="$(read_version_field "$version_file" '.install_mode' '"install_mode"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"

    local repo_dir=""
    repo_dir="$(read_version_field "$version_file" '.repoPath // .repo_path' '"repoPath"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    [[ -z "$repo_dir" ]] && repo_dir="$(read_version_field "$version_file" '.repo_path' '"repo_path"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    repo_dir="${repo_dir/#\~/$HOME}"

    if [[ "$install_mode" == "repo-link" ]]; then
        if [[ -n "$runtime_path" && -d "$runtime_path/.git" ]]; then
            printf '%s' "$runtime_path"
            return 0
        fi
        if [[ -n "$repo_dir" && -d "$repo_dir/.git" ]]; then
            printf '%s' "$repo_dir"
            return 0
        fi
        if [[ -n "$launcher_root" && -d "$launcher_root/.git" ]]; then
            printf '%s' "$launcher_root"
            return 0
        fi
    fi

    return 1
}

detect_runtime_path_for_help() {
    local candidate
    for candidate in "$config_dir" "$user_config_dir" "$system_config_dir" "$fallback_system_config_dir"; do
        if [[ -n "$candidate" && -f "$candidate/shell.qml" ]]; then
            printf '%s' "$candidate"
            return 0
        fi
    done
    return 1
}

service_link_summary() {
    if ! command -v systemctl >/dev/null 2>&1; then
        printf '%s' "unknown"
        return
    fi

    local links=()
    local wants_dir
    for wants_dir in "$systemd_user_dir"/*.wants; do
        [[ -d "$wants_dir" ]] || continue
        [[ -e "$wants_dir/inir.service" || -L "$wants_dir/inir.service" ]] || continue
        [[ "$(basename "$wants_dir")" == "graphical-session.target.wants" ]] && continue
        links+=("$(basename "${wants_dir%.wants}")")
    done

    if [[ ${#links[@]} -eq 0 ]]; then
        printf '%s' "disabled"
        return
    fi

    local IFS=', '
    printf '%s' "${links[*]}"
}

print_cli_context() {
    local version_file version install_mode update_strategy runtime_path setup_dir launcher_path branch service_state
    version_file="$(inir_version_file 2>/dev/null || true)"
    version="$(read_version_field "$version_file" '.version' '"version"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    install_mode="$(read_version_field "$version_file" '.installMode // .install_mode' '"installMode"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    [[ -z "$install_mode" ]] && install_mode="$(read_version_field "$version_file" '.install_mode' '"install_mode"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    update_strategy="$(read_version_field "$version_file" '.updateStrategy // .update_strategy' '"updateStrategy"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"
    [[ -z "$update_strategy" ]] && update_strategy="$(read_version_field "$version_file" '.update_strategy' '"update_strategy"[[:space:]]*:[[:space:]]*"\([^"]*\)"')"

    resolve_config_dir
    runtime_path="$(detect_runtime_path_for_help || true)"
    setup_dir="$(resolve_setup_dir 2>/dev/null || true)"
    launcher_path="$(resolve_launcher_path)"
    service_state="$(service_link_summary)"

    local live_repo=""
    live_repo="$(resolve_live_version_context "$version_file" "$runtime_path" || true)"
    if [[ -n "$live_repo" ]]; then
        [[ -f "$live_repo/VERSION" ]] && version="$(tr -d '[:space:]' < "$live_repo/VERSION")"
        install_mode="repo-link"
    fi

    printf 'Current context:\n'
    [[ -n "$version" ]] && printf '  version: %s\n' "$version"
    [[ -n "$install_mode" ]] && printf '  install mode: %s\n' "$install_mode"
    [[ -n "$update_strategy" ]] && printf '  update strategy: %s\n' "$update_strategy"
    [[ -n "$runtime_path" ]] && printf '  runtime: %s\n' "$runtime_path"
    [[ -n "$setup_dir" ]] && printf '  setup: %s\n' "$setup_dir"
    printf '  launcher: %s\n' "$launcher_path"
    printf '  service: %s\n' "$service_state"

    if [[ -n "$setup_dir" && -d "$setup_dir/.git" ]]; then
        branch="$(git -C "$setup_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
        if [[ -n "$branch" ]]; then
            printf '  branch: %s\n' "$branch"
            [[ "$branch" != "main" && "$branch" != "master" ]] && printf '  note: non-release branch\n'
        fi
    fi

    printf '\n'
}

service_usage() {
    local service_state
    service_state="$(service_link_summary)"
    cat <<EOF
Usage: inir service <install|uninstall|enable|disable|start|stop|restart|status|logs> [args...]

What it does:
  install     Write the user unit file from the current launcher path
  enable      Wire inir.service to the detected compositor service
  disable     Remove compositor wants links
  start       Start the user service
  stop        Stop the user service
  restart     Restart the user service
  status      Show systemd status
  logs        Tail journal logs for the service

Current service state:
  wiring: $service_state
  unit: ${systemd_user_dir}/inir.service

This never falls back to graphical-session.target, because that would be
stupid and start iNiR under desktops that should not touch it.
EOF
}

repair_usage() {
    cat <<'EOF'
Usage: inir repair [-c PATH]

What it does:
  1. runs setup doctor inline
  2. restarts the shell if a graphical session is available
  3. prints recent logs plus filtered errors

Use this when the shell feels cursed but you do not want to manually chain
doctor, restart, and log inspection yourself.
EOF
}

_usage_print_targets() {
    local header="$1"
    local family="$2"
    local targets=()
    local t

    for t in "${IPC_ALL_TARGETS[@]}"; do
        if [[ "${IPC_TARGET_FAMILY[$t]:-}" == "$family" ]]; then
            targets+=("$t")
        fi
    done

    if [[ ${#targets[@]} -eq 0 ]]; then
        return
    fi

    printf '%s\n' "$header"
    for t in "${targets[@]}"; do
        local desc="${IPC_TARGET_DESC[$t]:-}"
        # Truncate description to first sentence for compact display
        desc="${desc%%.*}"
        if [[ -n "$desc" ]]; then
            printf '    %-24s %s\n' "$t" "$desc"
        else
            printf '    %s\n' "$t"
        fi
    done
}

usage_short() {
    cat <<'EOF'
Most people only need:
  ./setup install
  inir run
  inir settings
  inir update
  inir status
  inir doctor
  inir overview toggle
  inir terminal
  inir browser
  inir colorpicker
  inir logs
  inir repair
  inir theme list-targets
  inir theme inspect terminals
  inir theme doctor
  inir theme scaffold myapp
  inir theme apply terminals
  ./setup
EOF
}

find_qs() {
    if [[ ! -x "$qs_bin" ]]; then
        qs_bin="$(command -v qs || true)"
    fi

    if [[ -z "${qs_bin:-}" || ! -x "$qs_bin" ]]; then
        echo "qs not found" >&2
        exit 1
    fi
}

# Lazy qs resolution: only validate qs binary for commands that actually need it.
# Non-runtime commands (install, update, doctor, status, help, version, etc.)
# must work without Quickshell installed.
require_qs() {
    if [[ -z "${_qs_resolved:-}" ]]; then
        find_qs
        _qs_resolved=1
    fi
}

# --- Quickshell install-kind detection ----------------------------------------
# Returns "kind:pkgname". Used by check_qs_abi() and `inir doctor --fix-abi`.
# Each kind needs a different rebuild path — there is no universal command:
#   arch-aur-foreign      built locally from AUR     -> paru -S --rebuild
#   arch-repo-binary      precompiled in 3rd-party repo (CachyOS, chaotic-aur)
#                                                     -> paru -Sa (forces source build)
#   arch-repo-official    extra/quickshell           -> sudo pacman -Syu (waits for maintainer)
#   arch-aur-bin          quickshell-bin (precompiled tarball)
#                                                     -> switch to quickshell-git
#   fedora-pkg            rpm/COPR install            -> sudo dnf upgrade
#   nixos                 nixpkgs/flake               -> nixos-rebuild switch --upgrade
#   debian                apt/dpkg                    -> compile from source
#   source                /usr/local install          -> compile from source
#   unknown               nothing matches             -> point at Quickshell docs
_inir_quickshell_install_kind() {
    if command -v pacman >/dev/null 2>&1; then
        if pacman -Qi quickshell-bin &>/dev/null; then
            printf 'arch-aur-bin:quickshell-bin'; return
        elif pacman -Qi quickshell-git &>/dev/null; then
            if pacman -Qm quickshell-git &>/dev/null; then
                printf 'arch-aur-foreign:quickshell-git'
            else
                printf 'arch-repo-binary:quickshell-git'
            fi
            return
        elif pacman -Qi quickshell &>/dev/null; then
            if pacman -Qm quickshell &>/dev/null; then
                printf 'arch-aur-foreign:quickshell'
            else
                printf 'arch-repo-official:quickshell'
            fi
            return
        fi
    elif command -v rpm >/dev/null 2>&1; then
        local q
        q="$(rpm -qa 2>/dev/null | grep -E '^quickshell(-git)?-[0-9]' | head -1)"
        if [[ -n "$q" ]]; then
            printf 'fedora-pkg:%s' "${q%%-[0-9]*}"; return
        fi
    elif [[ -d /etc/nixos ]] || [[ -L /run/current-system ]]; then
        printf 'nixos:quickshell'; return
    elif command -v dpkg >/dev/null 2>&1 && dpkg -s quickshell &>/dev/null; then
        printf 'debian:quickshell'; return
    elif [[ -x /usr/local/bin/quickshell || -x /usr/local/bin/qs ]]; then
        printf 'source:'; return
    fi
    printf 'unknown:'
}

# Echoes the rebuild command for a kind:pkg pair. Empty if no auto-rebuild path exists.
_inir_quickshell_rebuild_cmd() {
    local kind="${1%%:*}" pkg="${1#*:}"
    local helper=""
    if [[ "$kind" == arch-* ]]; then
        for h in paru yay; do
            if command -v "$h" >/dev/null 2>&1; then helper="$h"; break; fi
        done
        [[ -z "$helper" ]] && return  # No AUR helper means no automatic Arch path
    fi
    case "$kind" in
        arch-aur-foreign)   printf '%s -S --rebuild --noconfirm %s' "$helper" "$pkg" ;;
        arch-repo-binary)   printf '%s -Sa --noconfirm --skipreview %s' "$helper" "$pkg" ;;
        arch-repo-official) printf 'sudo pacman -Syu --noconfirm' ;;
        arch-aur-bin)       printf '%s -Rdd --noconfirm quickshell-bin && %s -Sa --noconfirm --skipreview quickshell-git' "$helper" "$helper" ;;
        fedora-pkg)         printf 'sudo dnf upgrade --refresh -y %s' "$pkg" ;;
        nixos)              printf 'sudo nixos-rebuild switch --upgrade' ;;
        debian|source|unknown|*) ;;  # No automatic path
    esac
}

# Pure ABI detection: returns 0 if compatible, 1 if mismatched. Sets globals
# _inir_abi_buildtime / _inir_abi_runtime / _inir_abi_msg for callers to use.
_inir_quickshell_abi_status() {
    _inir_abi_buildtime=""
    _inir_abi_runtime=""
    _inir_abi_msg=""
    local qs_bin
    qs_bin="$(command -v qs 2>/dev/null || command -v quickshell 2>/dev/null)"
    [[ -z "$qs_bin" ]] && return 0  # No qs installed = no mismatch to detect

    local qs_output
    qs_output="$("$qs_bin" --version 2>&1 || true)"
    if echo "$qs_output" | grep -qiE "built against Qt|Qt.*mismatch|incompatible Qt"; then
        _inir_abi_msg="$(echo "$qs_output" | grep -iE "built against Qt|Qt.*mismatch|incompatible Qt" | head -1)"
        return 1
    fi

    if command -v strings >/dev/null 2>&1; then
        _inir_abi_buildtime="$(strings "$qs_bin" 2>/dev/null | grep -P '^6\.\d+\.\d+$' | head -1 || true)"
        local qt_lib_path=""
        [[ -e /usr/lib/libQt6Core.so.6 ]] && qt_lib_path="/usr/lib/libQt6Core.so.6"
        [[ -z "$qt_lib_path" && -e /usr/lib64/libQt6Core.so.6 ]] && qt_lib_path="/usr/lib64/libQt6Core.so.6"
        if [[ -n "$qt_lib_path" ]]; then
            _inir_abi_runtime="$(readlink -f "$qt_lib_path" 2>/dev/null | grep -oP '[0-9]+\.[0-9]+\.[0-9]+$' || true)"
        fi
        if [[ -z "$_inir_abi_runtime" ]] && command -v pkg-config >/dev/null 2>&1; then
            _inir_abi_runtime="$(pkg-config --modversion Qt6Core 2>/dev/null || true)"
        fi
        if [[ -n "$_inir_abi_buildtime" && -n "$_inir_abi_runtime" && "$_inir_abi_buildtime" != "$_inir_abi_runtime" ]]; then
            _inir_abi_msg="Quickshell built against Qt $_inir_abi_buildtime but system has Qt $_inir_abi_runtime"
            return 1
        fi
    fi
    return 0
}

# Auto-fix the ABI mismatch by rebuilding quickshell. Returns 0 on success.
# $1 = "interactive" (default; prompts before running) | "noninteractive" (just runs)
# Side effect: invalidates ~/.cache/inir/abi-check after a successful rebuild so
# subsequent check_qs_abi calls re-scan the fresh binary.
_inir_run_quickshell_rebuild() {
    local mode="${1:-interactive}"

    # Precheck: don't waste 5 minutes rebuilding when nothing is wrong.
    if _inir_quickshell_abi_status; then
        echo "iNiR: Quickshell/Qt ABI is already compatible — nothing to do." >&2
        if [[ -n "$_inir_abi_buildtime" ]]; then
            echo "      Build-time Qt: $_inir_abi_buildtime  ≡  Runtime Qt: $_inir_abi_runtime" >&2
        fi
        return 0
    fi

    echo "iNiR: Qt/Quickshell ABI mismatch — $_inir_abi_msg" >&2

    local kind_pkg cmd
    kind_pkg="$(_inir_quickshell_install_kind)"
    cmd="$(_inir_quickshell_rebuild_cmd "$kind_pkg")"
    if [[ -z "$cmd" ]]; then
        echo "iNiR: cannot auto-rebuild Quickshell — install kind '${kind_pkg%%:*}' has no automatic path." >&2
        echo "      See: https://quickshell.org/docs/master/guide/install-setup" >&2
        return 1
    fi

    echo "iNiR: planned fix → ${cmd//--noconfirm/}" >&2

    if [[ "$mode" == "interactive" && -t 0 && -t 1 ]]; then
        local resp
        read -r -p "Run this fix now to rebuild quickshell? [Y/n] " resp || true
        case "${resp:-}" in
            ""|[Yy]*) ;;
            *) echo "iNiR: rebuild declined." >&2; return 1 ;;
        esac
    fi

    echo "iNiR: rebuilding quickshell against the current Qt version (this can take a few minutes)..." >&2
    if eval "$cmd"; then
        rm -f "${XDG_CACHE_HOME:-$HOME/.cache}/inir/abi-check" 2>/dev/null
        echo "iNiR: Quickshell rebuilt successfully." >&2
        return 0
    fi
    echo "iNiR: rebuild failed. Try manually: ${cmd//--noconfirm/}" >&2
    return 1
}

check_qs_abi() {
    # Quickshell uses Qt private APIs — any Qt minor version bump (e.g. 6.10→6.11)
    # breaks ABI and crashes the shell on any UI interaction.
    # This pre-check catches the issue before starting a crash loop.
    # See: https://github.com/snowarch/iNiR/issues/93
    local mismatch_detected=false
    local mismatch_msg=""

    # Primary: qs --version may print mismatch warning on stderr
    local qs_output
    qs_output="$("$qs_bin" --version 2>&1 || true)"
    if echo "$qs_output" | grep -qiE "built against Qt|Qt.*mismatch|incompatible Qt"; then
        mismatch_detected=true
        mismatch_msg="$(echo "$qs_output" | grep -iE "built against Qt|Qt.*mismatch|incompatible Qt" | head -1)"
    fi

    # Secondary: compare compile-time Qt (from binary strings) vs runtime Qt (from lib symlink).
    # Cache the result keyed on binary mtimes to avoid re-running `strings` on every start.
    if ! $mismatch_detected && command -v strings >/dev/null 2>&1; then
        local abi_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/inir"
        local abi_cache_file="$abi_cache_dir/abi-check"
        local qs_mtime qt_mtime abi_cache_key
        qs_mtime="$(stat -c %Y "$qs_bin" 2>/dev/null || echo 0)"
        local qt_lib_path=""
        if [[ -e /usr/lib/libQt6Core.so.6 ]]; then
            qt_lib_path="/usr/lib/libQt6Core.so.6"
        elif [[ -e /usr/lib64/libQt6Core.so.6 ]]; then
            qt_lib_path="/usr/lib64/libQt6Core.so.6"
        fi
        qt_mtime="$(stat -c %Y "$(readlink -f "$qt_lib_path" 2>/dev/null || echo "$qt_lib_path")" 2>/dev/null || echo 0)"
        # v2 prefix invalidates pre-fix caches that passed under major.minor-only comparison
        # (those would have wrongly cached a pass for e.g. 6.11.0 -> 6.11.1 patch bumps).
        abi_cache_key="v2:${qs_mtime}:${qt_mtime}"

        if [[ -f "$abi_cache_file" ]] && [[ "$(<"$abi_cache_file")" == "$abi_cache_key" ]]; then
            # Cached pass — same binaries as last successful check
            return 0
        fi

        local buildtime_qt=""
        local runtime_qt=""
        buildtime_qt="$(strings "$qs_bin" 2>/dev/null | grep -P '^6\.\d+\.\d+$' | head -1 || true)"
        if [[ -n "$qt_lib_path" ]]; then
            runtime_qt="$(readlink -f "$qt_lib_path" 2>/dev/null | grep -oP '[0-9]+\.[0-9]+\.[0-9]+$' || true)"
        fi
        if [[ -z "$runtime_qt" ]] && command -v pkg-config >/dev/null 2>&1; then
            runtime_qt="$(pkg-config --modversion Qt6Core 2>/dev/null || true)"
        fi
        # Compare full version (major.minor.patch). Quickshell warns on patch bumps too
        # (private API changes between 6.11.0 and 6.11.1 are common), so iNiR must match.
        if [[ -n "$buildtime_qt" && -n "$runtime_qt" && "$buildtime_qt" != "$runtime_qt" ]]; then
            mismatch_detected=true
            mismatch_msg="Quickshell built against Qt $buildtime_qt but system has Qt $runtime_qt"
        fi

        # Cache successful result so next start skips the expensive strings scan
        if ! $mismatch_detected; then
            mkdir -p "$abi_cache_dir" 2>/dev/null || true
            printf '%s' "$abi_cache_key" > "$abi_cache_file" 2>/dev/null || true
        fi
    fi

    if ! $mismatch_detected; then
        return 0
    fi

    echo "" >&2
    echo "ERROR: Qt/Quickshell ABI mismatch detected" >&2
    echo "  $mismatch_msg" >&2
    echo "" >&2
    echo "Quickshell was built against a different Qt version than what is installed." >&2
    echo "The shell will crash on any UI interaction until quickshell is rebuilt." >&2

    # Detect-AND-fix: when interactive, offer the rebuild on the spot.
    # That's the whole point of having a doctor — not just blame the user.
    if [[ -t 0 && -t 1 ]] && _inir_run_quickshell_rebuild interactive; then
        return 0
    fi

    # Auto-fix declined, unavailable, or failed — fall through to manual instructions.
    echo "" >&2
    local _kind_pkg _fix_cmd
    _kind_pkg="$(_inir_quickshell_install_kind)"
    _fix_cmd="$(_inir_quickshell_rebuild_cmd "$_kind_pkg")"
    if [[ -n "$_fix_cmd" ]]; then
        echo "Manual fix: ${_fix_cmd//--noconfirm/}" >&2
    else
        echo "Manual fix: rebuild quickshell from source against the current Qt version." >&2
        echo "            See https://quickshell.org/docs/master/guide/install-setup" >&2
    fi
    echo "Or run non-interactively: inir doctor --fix-abi --noninteractive" >&2
    echo "" >&2
    exit 1
}

# Warn if code version differs from what setup last installed.
# Catches the case where a user does `git pull` in a repo-link checkout
# without running `./setup update` — new QML loads via hot-reload but
# infrastructure (launcher, migrations, config dir) stays stale.
check_setup_version_sync() {
    local dir="$1"
    local code_version=""
    local installed_version=""

    # Read VERSION from the code about to be loaded
    if [[ -f "$dir/VERSION" ]]; then
        code_version="$(<"$dir/VERSION")"
        code_version="${code_version%%[[:space:]]*}"
    fi

    [[ -z "$code_version" ]] && return 0

    # Read version from version.json (written by setup at install/update time)
    local version_json
    version_json="$(inir_version_file 2>/dev/null || echo "")"
    [[ -z "$version_json" || ! -f "$version_json" ]] && return 0

    if command -v jq >/dev/null 2>&1; then
        installed_version="$(jq -r '.version // empty' "$version_json" 2>/dev/null || true)"
    else
        installed_version="$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$version_json" 2>/dev/null \
            | head -1 | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)"
    fi

    [[ -z "$installed_version" ]] && return 0

    if [[ "$code_version" != "$installed_version" ]]; then
        echo "" >&2
        echo "WARNING: Code version ($code_version) differs from installed version ($installed_version)" >&2
        echo "  This usually means you updated the code (git pull) without running setup." >&2
        echo "  Run: ./setup update   or   inir update" >&2
        echo "" >&2
    fi
}

canonicalize_path() {
    local candidate="${1:-}"
    if [[ -z "$candidate" ]]; then
        printf '%s' "$candidate"
        return
    fi
    if command -v readlink >/dev/null 2>&1; then
        readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate"
    else
        printf '%s' "$candidate"
    fi
}

detect_running_instance_dir() {
    # Find the config directory of an already-running iNiR shell instance.
    # Returns 0 and prints the dir if found, returns 1 otherwise.
    local running_path=""

    if command -v jq >/dev/null 2>&1; then
        local json_output
        json_output="$($qs_bin list --all --json 2>/dev/null || true)"
        if [[ -n "$json_output" && "$json_output" != "[]" ]]; then
            running_path="$(printf '%s' "$json_output" | jq -r '
                [.[] | (.config_path // .configPath // empty) | select(endswith("/shell.qml"))]
                | .[0] // empty
            ' 2>/dev/null || true)"
        fi
    fi

    # Fallback: parse text output
    if [[ -z "$running_path" ]]; then
        local text_output
        text_output="$($qs_bin list --all 2>/dev/null || true)"
        if [[ -n "$text_output" ]]; then
            running_path="$(printf '%s' "$text_output" | sed -n 's/^[[:space:]]*Config path:[[:space:]]*//p' | grep '/shell\.qml$' | head -1)"
        fi
    fi

    if [[ -n "$running_path" ]]; then
        local dir="${running_path%/shell.qml}"
        if [[ -d "$dir" && -f "$dir/shell.qml" ]]; then
            printf '%s' "$dir"
            return 0
        fi
    fi

    return 1
}

apply_shell_scale() {
    # Shell scaling is now handled entirely in QML via appearance.typography.sizeScale
    # (live, no restart required). QT_SCALE_FACTOR must always be 1 to avoid geometry
    # bugs where the compositor surface is larger than the Qt-rendered content area,
    # which causes wallpaper/blur layers to appear smaller than the screen.
    export QT_SCALE_FACTOR=1
}

wait_for_wayland_socket() {
    # Block until a Wayland compositor socket appears in XDG_RUNTIME_DIR.
    # At session boot, systemd may start inir.service before the compositor
    # (Niri/Hyprland) has created its socket.  Without WAYLAND_DISPLAY, Qt
    # falls back to XCB and crashes (SIGABRT — no X11 server on Wayland-only).
    # Polling here is cheaper than crash-restart loops and gives instant start
    # the moment the socket appears.
    [[ -n "${WAYLAND_DISPLAY:-}" ]] && return 0

    local runtime_dir="/run/user/$(id -u)"
    local max_polls=50  # 50 × 0.2s = 10 seconds max
    local i=0

    while (( i < max_polls )); do
        local candidate
        for candidate in "$runtime_dir"/wayland-[0-9]*; do
            if [[ -S "$candidate" ]]; then
                export WAYLAND_DISPLAY="$(basename "$candidate")"
                return 0
            fi
        done
        sleep 0.2
        (( i++ )) || true
    done

    echo "Warning: No Wayland socket found after ~10s — Qt may crash" >&2
    return 1
}

apply_hot_reload_policy_for_dir() {
    local dir="$1"

    if [[ -n "${INIR_DISABLE_HOT_RELOAD+x}" || -z "$dir" ]]; then
        return
    fi

    # Developer checkouts keep .git; deployed runtime payloads do not.
    # Disable file watching for deployed payloads to reduce startup overhead,
    # while preserving hot reload when running directly from a git checkout.
    if [[ -e "$dir/.git" ]]; then
        return
    fi

    export INIR_DISABLE_HOT_RELOAD=1
}

# Cached systemd user environment — avoids duplicate blocking calls.
# On fresh boot, `systemctl --user show-environment` can block for 10-30s
# waiting for D-Bus session activation.  We call it once with a tight
# timeout and cache the result for both apply_qt_runtime_env() and
# ensure_systemd_graphical_env(), cutting worst-case startup from ~60s to ~3s.
_cached_systemd_env=""
_cached_systemd_env_fetched=false

_get_systemd_user_env() {
    if [[ "$_cached_systemd_env_fetched" == true ]]; then
        printf '%s' "$_cached_systemd_env"
        return 0
    fi
    _cached_systemd_env_fetched=true
    # 3s timeout: if D-Bus isn't ready yet, bail out and let the shell start
    # with whatever env it already has.  Apps launched later will inherit the
    # full env from systemd once it catches up.
    _cached_systemd_env="$(timeout 3s systemctl --user show-environment 2>/dev/null)" || true
    printf '%s' "$_cached_systemd_env"
}

apply_gpu_policy() {
    # Pin Qt/Mesa to the iGPU on hybrid laptops so the dGPU can stay in
    # runtime PM suspend.  Coupled to resources.monitorGpu (Settings UI):
    # only fires when the user disabled GPU monitoring.  See #106, #136.
    # Hard opt-out: INIR_GPU_FORCE_DEFAULT=1.
    [[ "${INIR_GPU_FORCE_DEFAULT:-0}" == "1" ]] && return

    local monitor_gpu="true"
    if command -v jq >/dev/null 2>&1; then
        local _gpu_cfg
        _gpu_cfg="$(inir_config_file 2>/dev/null)"
        if [[ -n "$_gpu_cfg" && -f "$_gpu_cfg" ]]; then
            monitor_gpu="$(jq -r '.resources.monitorGpu // true' "$_gpu_cfg" 2>/dev/null || true)"
            [[ -z "$monitor_gpu" ]] && monitor_gpu="true"
        fi
    fi
    [[ "$monitor_gpu" == "true" ]] && return

    # Hybrid detection via DRM boot_vga (1=iGPU primary, 0=dGPU secondary).
    local igpu_pci="" has_dgpu=""
    local card bvga_file boot_vga dev_link
    for card in /sys/class/drm/card*; do
        [[ -d "$card" ]] || continue
        bvga_file="${card}/device/boot_vga"
        [[ -f "$bvga_file" ]] || continue
        boot_vga=$(cat "$bvga_file" 2>/dev/null)
        if [[ "$boot_vga" == "1" && -z "$igpu_pci" ]]; then
            dev_link=$(readlink -f "${card}/device" 2>/dev/null)
            igpu_pci=$(printf '%s\n' "$dev_link" | grep -oE '[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]' | tail -1)
        elif [[ "$boot_vga" == "0" ]]; then
            has_dgpu=1
        fi
    done
    [[ -z "$has_dgpu" || -z "$igpu_pci" ]] && return

    # Vulkan loader: skip NVIDIA's ICD entirely (loader 1.3.207+).  Without
    # this the loader dlopens libnvidia-* during enumeration, which is what
    # opens the /dev/nvidia* fds in #136's lsof.
    [[ -z "${VK_LOADER_DRIVERS_DISABLE:-}" ]] && export VK_LOADER_DRIVERS_DISABLE="*nvidia*"
    # Mesa Vulkan device-select: prefer the iGPU PCI bus.
    [[ -z "${MESA_VK_DEVICE_SELECT:-}" ]] && export MESA_VK_DEVICE_SELECT="pci-$igpu_pci"
    [[ -z "${MESA_VK_DEVICE_SELECT_FORCE_DEFAULT_DEVICE:-}" ]] && export MESA_VK_DEVICE_SELECT_FORCE_DEFAULT_DEVICE=1
    # GLVND: OpenGL via Mesa, not NVIDIA's libGLX.
    [[ -z "${__GLX_VENDOR_LIBRARY_NAME:-}" ]] && export __GLX_VENDOR_LIBRARY_NAME=mesa
    [[ -z "${__NV_PRIME_RENDER_OFFLOAD:-}" ]] && export __NV_PRIME_RENDER_OFFLOAD=0
    # Qt FFmpeg: no NVDEC/CUDA hwaccel.
    [[ -z "${QT_FFMPEG_DECODING_HW_DEVICE_TYPES+x}" ]] && export QT_FFMPEG_DECODING_HW_DEVICE_TYPES=
    # NVIDIA optimus Vulkan layer: pretend iGPU only.
    [[ -z "${__VK_LAYER_NV_optimus:-}" ]] && export __VK_LAYER_NV_optimus=non_NVIDIA_only
    # VDPAU: Qt FFmpeg probes libvdpau_nvidia.so on init even with hwaccel off.
    [[ -z "${VDPAU_DRIVER:-}" ]] && export VDPAU_DRIVER=none
}

apply_qt_runtime_env() {
    # Must run before Qt reads env at QGuiApplication construction.
    apply_gpu_policy

    # Ensure WAYLAND_DISPLAY is set — required for Qt to select the wayland
    # platform backend.  When systemd starts inir.service at boot, the
    # compositor may not have exported WAYLAND_DISPLAY into the user manager
    # environment yet.  Without it Qt falls back to XCB, which crashes on a
    # headless Wayland session (no X11 display) and delays shell startup long
    # enough for tray apps to miss the StatusNotifierWatcher.
    if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
        local candidate
        for candidate in /run/user/"$(id -u)"/wayland-[0-9]*; do
            if [[ -S "$candidate" ]]; then
                export WAYLAND_DISPLAY="$(basename "$candidate")"
                break
            fi
        done
    fi

    # NIRI_SOCKET — NiriService.qml reads this via Quickshell.env("NIRI_SOCKET")
    # as a readonly property at instantiation time, so it must be present in the
    # process environment before QS starts.
    # At session boot, inir.service races with Niri's own import-environment call:
    # graphical-session.target activates → systemd starts inir.service immediately,
    # but Niri only propagates NIRI_SOCKET to the user manager a moment later.
    # Result: QS reads an empty string → NiriService never connects → workspaces,
    # window management, and all Niri IPC broken until inir restart.
    # Fix: detect the socket directly from the filesystem so QS always gets a valid
    # path regardless of import-environment timing.
    # Niri socket format: $XDG_RUNTIME_DIR/niri.wayland-N.PID.sock
    # Older/some builds also use: $XDG_RUNTIME_DIR/niri/socket
    if [[ -z "${NIRI_SOCKET:-}" ]]; then
        local _runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
        local _niri_cand
        # Current Niri format: niri.wayland-N.PID.sock
        for _niri_cand in "$_runtime_dir"/niri.wayland-*.sock; do
            if [[ -S "$_niri_cand" ]]; then
                export NIRI_SOCKET="$_niri_cand"
                break
            fi
        done
        # Legacy/alternative path
        if [[ -z "${NIRI_SOCKET:-}" && -S "$_runtime_dir/niri/socket" ]]; then
            export NIRI_SOCKET="$_runtime_dir/niri/socket"
        fi
    fi

    # Qt platform theme drives icon resolution (QIcon::fromTheme) and widget styling.
    # Override via INIR_QT_QPA_PLATFORMTHEME / INIR_QT_STYLE_OVERRIDE if needed.
    if [[ -n "${INIR_QT_QPA_PLATFORMTHEME+x}" ]]; then
        export QT_QPA_PLATFORMTHEME="$INIR_QT_QPA_PLATFORMTHEME"
    elif [[ -z "${QT_QPA_PLATFORMTHEME:-}" ]]; then
        # Session doesn't provide a platform theme — detect a sane default.
        # Without this, Qt can't resolve icon themes and all icons show as missing.
        if command -v kwriteconfig6 &>/dev/null || [[ -f /usr/lib/qt6/plugins/platformthemes/KDEPlasmaPlatformTheme.so ]] || [[ -f /usr/lib64/qt6/plugins/platformthemes/KDEPlasmaPlatformTheme.so ]]; then
            export QT_QPA_PLATFORMTHEME=kde
        elif command -v gsettings &>/dev/null && [[ -f /usr/lib/qt6/plugins/platformthemes/libqgtk3.so || -f /usr/lib64/qt6/plugins/platformthemes/libqgtk3.so ]]; then
            export QT_QPA_PLATFORMTHEME=gtk3
        fi
    fi

    if [[ -n "${INIR_QT_STYLE_OVERRIDE+x}" ]]; then
        export QT_STYLE_OVERRIDE="$INIR_QT_STYLE_OVERRIDE"
    fi

    # Ensure XDG_DATA_DIRS includes standard icon paths — some sessions omit it.
    if [[ -z "${XDG_DATA_DIRS:-}" ]]; then
        export XDG_DATA_DIRS="/usr/local/share:/usr/share"
        [[ -d "$HOME/.local/share/flatpak/exports/share" ]] && \
            XDG_DATA_DIRS="$HOME/.local/share/flatpak/exports/share:$XDG_DATA_DIRS"
        [[ -d "/var/lib/flatpak/exports/share" ]] && \
            XDG_DATA_DIRS="/var/lib/flatpak/exports/share:$XDG_DATA_DIRS"
        true
    fi

    # Import missing graphical-session variables from the systemd user manager.
    #
    # When inir.service races compositor startup (graphical-session.target),
    # the process environment is minimal (PATH=/usr/local/bin:/usr/bin, no
    # XDG_SESSION_TYPE, no DISPLAY, no XCURSOR_*, etc.).  By the time
    # wait_for_wayland_socket() returns, the compositor (niri/hyprland) has
    # already run its import-environment step, so the systemd user manager's
    # environment is complete.  We pull any still-missing critical vars into
    # this process so that Quickshell's INITIAL_ENVIRONMENT snapshot — which
    # is frozen at QS startup and inherited by every app launched via
    # DesktopEntry.execute() — contains them.
    #
    # Without this:
    #   • Chromium/Brave/Electron apps don't see XDG_SESSION_TYPE=wayland and
    #     fall back to X11; with no DISPLAY set they fail silently.
    #   • Apps in ~/.local/bin, flatpak exports, nvm, pnpm, etc. are not found
    #     because PATH is the bare systemd minimum.
    #   • Cursor theme/size are absent, so spawned apps render the default cursor.
    local _qs_sys_env
    _qs_sys_env="$(_get_systemd_user_env)"
    if [[ -n "$_qs_sys_env" ]]; then
        local _qs_var _qs_val
        for _qs_var in XDG_SESSION_TYPE XDG_SESSION_DESKTOP DESKTOP_SESSION \
                       DISPLAY XCURSOR_THEME XCURSOR_SIZE \
                       LANG LC_ALL XDG_MENU_PREFIX \
                       ELECTRON_OZONE_PLATFORM_HINT QT_STYLE_OVERRIDE \
                       GDK_BACKEND; do
            if [[ -z "${!_qs_var:-}" ]]; then
                _qs_val="$(grep "^${_qs_var}=" <<< "$_qs_sys_env" | head -1 | cut -d= -f2- || true)"
                [[ -n "$_qs_val" ]] && export "${_qs_var}=${_qs_val}"
            fi
        done
        # Use the manager's rich PATH (set by compositor + PAM login) which
        # includes user dirs (~/.local/bin, flatpak exports, nvm, pnpm, etc.)
        # absent from the minimal systemd unit PATH.  All apps launched via
        # DesktopEntry.execute() inherit Quickshell's INITIAL_ENVIRONMENT, so
        # they need the full PATH to locate binaries outside /usr/bin.
        local _qs_sys_path
        _qs_sys_path="$(grep '^PATH=' <<< "$_qs_sys_env" | head -1 | cut -d= -f2- || true)"
        if [[ -n "$_qs_sys_path" && "$_qs_sys_path" != "$PATH" ]]; then
            local _qs_merged="$_qs_sys_path"
            for _qs_p in /usr/local/bin /usr/bin; do
                case ":${_qs_merged}:" in
                    *":${_qs_p}:"*) ;;
                    *) _qs_merged="${_qs_merged}:${_qs_p}" ;;
                esac
            done
            export PATH="$_qs_merged"
        fi
    fi

    # Electron Wayland hint — must be in the process env so launched Electron apps
    # (Discord, VS Code, Chrome, Brave) use Wayland natively instead of X11.
    # The systemd import above may already have set it; this is the hardcoded fallback
    # for race conditions where niri hasn't propagated it yet.
    if [[ -z "${ELECTRON_OZONE_PLATFORM_HINT:-}" ]]; then
        export ELECTRON_OZONE_PLATFORM_HINT=auto
    fi
}

apply_qt_logging_rules() {
    local extra_rules="quickshell.dbus.properties=false;qt.qml.settings.warning=false;qt.core.qsettings.warning=false;kf.xmlgui=false;kf.coreaddons=false;kf.config.core=false;kf.iconthemes=false"

    if [[ -z "${QT_LOGGING_RULES:-}" ]]; then
        export QT_LOGGING_RULES="$extra_rules"
        return
    fi

    case ";${QT_LOGGING_RULES};" in
        *";qt.core.qsettings.warning=false;"*)
            ;;
        *)
            export QT_LOGGING_RULES="${QT_LOGGING_RULES};${extra_rules}"
            ;;
    esac
}

resolve_config_dir() {
    if [[ -n "$config_dir" ]]; then
        if [[ ! -f "$config_dir/shell.qml" ]]; then
            echo "Invalid iNiR config path: $config_dir" >&2
            exit 1
        fi
        config_dir="$(canonicalize_path "$config_dir")"
        return
    fi

    # Prefer the path of an already-running instance to avoid path-identity
    # mismatches where the launcher would target a different path than the
    # running shell (e.g. dev repo vs setup-installed symlink).
    # Skip this probe during session boot (no running instance, saves a qs subprocess).
    if [[ "${_skip_running_detect:-}" != true ]]; then
        local running
        if running="$(detect_running_instance_dir)"; then
            config_dir="$(canonicalize_path "$running")"
            return
        fi
    fi

    local candidate
    for candidate in "$user_config_dir" "$system_config_dir" "$fallback_system_config_dir"; do
        if [[ -n "$candidate" && -f "$candidate/shell.qml" ]]; then
            config_dir="$(canonicalize_path "$candidate")"
            return
        fi
    done

    echo "Could not find an iNiR shell payload" >&2
    exit 1
}

list_instances() {
    "$qs_bin" -p "$1" list 2>/dev/null || true
}

has_instances() {
    local output
    output="$(list_instances "$1")"
    [[ -n "$output" && "$output" != No\ running\ instances* ]]
}

ensure_running_instance() {
    local dir="$1"

    if has_instances "$dir"; then
        return 0
    fi

    apply_shell_scale
    apply_qt_runtime_env
    apply_qt_logging_rules
    check_qs_abi
    start_background "$dir"
    wait_for_start "$dir"
}

ensure_running_instance_for_ipc() {
    local dir="$1"
    local function_name="${2:-}"

    if has_instances "$dir"; then
        return 0
    fi

    case "$function_name" in
        close|hide|deactivate|dismiss)
            return 0
            ;;
    esac

    ensure_running_instance "$dir"
}

wait_for_start() {
    local dir="$1"
    local poll
    for ((poll = 0; poll < max_polls; poll++)); do
        if has_instances "$dir"; then
            return 0
        fi
        sleep "$poll_delay"
    done
    return 1
}

wait_for_stop() {
    local dir="$1"
    local poll
    for ((poll = 0; poll < max_polls; poll++)); do
        local output
        output="$(list_instances "$dir")"
        if [[ "$output" == No\ running\ instances* ]]; then
            return 0
        fi
        sleep "$poll_delay"
    done
    return 1
}

is_inir_service_enabled() {
    if ! command -v systemctl >/dev/null 2>&1; then
        return 1
    fi

    # The unit has no [Install] section — enablement is managed by a wants link
    # under the compositor service (e.g. niri.service.wants/inir.service).
    # Only count links under compositor-specific dirs, not graphical-session.target
    # (which fires under any DE including KDE/GNOME).
    local wants_dir
    for wants_dir in "$systemd_user_dir"/*.wants; do
        [[ -d "$wants_dir" ]] || continue
        # Skip graphical-session.target.wants — it's not compositor-specific
        [[ "$(basename "$wants_dir")" == "graphical-session.target.wants" ]] && continue
        if [[ -e "$wants_dir/inir.service" || -L "$wants_dir/inir.service" ]]; then
            return 0
        fi
    done
    return 1
}

detect_compositor_service() {
    # Determine the compositor service unit to wire inir to.
    # Priority: running compositor > socket detection > no fallback.
    #
    # Returns the unit name (e.g. "niri.service") on stdout.
    # Returns empty and exit 1 if no supported compositor service is found.
    # NEVER falls back to graphical-session.target — that would cause inir
    # to start under KDE/GNOME/etc.

    # 1. niri.service — ships static with niri, always available when niri is installed
    if systemctl --user cat niri.service &>/dev/null; then
        printf 'niri.service\n'
        return 0
    fi

    # 2. Hyprland via UWSM — creates wayland-wm@Hyprland.service
    if systemctl --user cat 'wayland-wm@Hyprland.service' &>/dev/null; then
        printf 'wayland-wm@Hyprland.service\n'
        return 0
    fi

    # 3. No supported compositor found
    return 1
}

ensure_systemd_graphical_env() {
    # Ensure the systemd user manager has critical graphical session variables.
    # Some sessions/DMs don't export these to systemd, which breaks the shell.
    local vars_to_import=()

    # Check what systemd already has
    local sys_env
    sys_env="$(_get_systemd_user_env)"

    # WAYLAND_DISPLAY — required for Quickshell to connect to compositor
    if ! grep -q '^WAYLAND_DISPLAY=' <<< "$sys_env" 2>/dev/null; then
        local wl_sock=""
        local candidate
        for candidate in /run/user/"$(id -u)"/wayland-[0-9]*; do
            if [[ -S "$candidate" ]]; then
                wl_sock="$(basename "$candidate")"
                break
            fi
        done
        if [[ -n "$wl_sock" ]]; then
            vars_to_import+=("WAYLAND_DISPLAY=$wl_sock")
        fi
    fi

    # NIRI_SOCKET — required for NiriService IPC (workspaces, windows, outputs).
    # Propagate to systemd user manager so service restarts also inherit it.
    # Niri socket format: $XDG_RUNTIME_DIR/niri.wayland-N.PID.sock
    if ! grep -q '^NIRI_SOCKET=' <<< "$sys_env" 2>/dev/null; then
        local _niri_runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
        local _niri_found=""
        local _nc
        for _nc in "$_niri_runtime"/niri.wayland-*.sock; do
            if [[ -S "$_nc" ]]; then
                _niri_found="$_nc"
                break
            fi
        done
        [[ -z "$_niri_found" && -S "$_niri_runtime/niri/socket" ]] && _niri_found="$_niri_runtime/niri/socket"
        [[ -n "$_niri_found" ]] && vars_to_import+=("NIRI_SOCKET=$_niri_found")
    fi

    # QT_QPA_PLATFORMTHEME — required for icon theme resolution
    if ! grep -q '^QT_QPA_PLATFORMTHEME=' <<< "$sys_env" 2>/dev/null; then
        if command -v kwriteconfig6 &>/dev/null; then
            vars_to_import+=("QT_QPA_PLATFORMTHEME=kde")
        elif command -v gsettings &>/dev/null; then
            vars_to_import+=("QT_QPA_PLATFORMTHEME=gtk3")
        fi
    fi

    # XDG_DATA_DIRS — required for icon/theme/app discovery
    if ! grep -q '^XDG_DATA_DIRS=' <<< "$sys_env" 2>/dev/null; then
        vars_to_import+=("XDG_DATA_DIRS=/usr/local/share:/usr/share")
    fi

    # XDG_CURRENT_DESKTOP — used by portal and theme detection
    if ! grep -q '^XDG_CURRENT_DESKTOP=' <<< "$sys_env" 2>/dev/null; then
        vars_to_import+=("XDG_CURRENT_DESKTOP=niri")
    fi

    # XDG_SESSION_TYPE — required by Chromium/Electron/Wine to select the Wayland
    # backend.  Without it they fall back to X11; if DISPLAY is also absent (common
    # in systemd-launched shells) they fail to open a window entirely.
    if ! grep -q '^XDG_SESSION_TYPE=' <<< "$sys_env" 2>/dev/null; then
        vars_to_import+=("XDG_SESSION_TYPE=wayland")
    fi

    # ELECTRON_OZONE_PLATFORM_HINT — tells Electron apps (Discord, VS Code, Chrome)
    # to use Wayland natively.  Niri sets this in its environment{} block for
    # processes it spawns directly, but Quickshell runs as a systemd service so
    # apps launched from the shell's Overview/launcher inherit the systemd user
    # session env instead, which misses this variable.
    if ! grep -q '^ELECTRON_OZONE_PLATFORM_HINT=' <<< "$sys_env" 2>/dev/null; then
        vars_to_import+=("ELECTRON_OZONE_PLATFORM_HINT=auto")
    fi

    # QT_QPA_PLATFORM — tells Qt apps to use the Wayland backend.  Qt usually
    # auto-detects this from WAYLAND_DISPLAY, but some apps (especially those using
    # older Qt builds or custom platform plugin paths) need it explicit.  Portal
    # services reading systemd env also benefit.
    if ! grep -q '^QT_QPA_PLATFORM=' <<< "$sys_env" 2>/dev/null; then
        vars_to_import+=("QT_QPA_PLATFORM=wayland")
    fi

    # QT_STYLE_OVERRIDE — ensures Qt apps launched from portals or systemd-triggered
    # contexts use the correct widget style (e.g. Darkly for dark KDE themes).
    # Only set if the compositor provided it (via environment{} block).
    if ! grep -q '^QT_STYLE_OVERRIDE=' <<< "$sys_env" 2>/dev/null; then
        if [[ -n "${QT_STYLE_OVERRIDE:-}" ]]; then
            vars_to_import+=("QT_STYLE_OVERRIDE=$QT_STYLE_OVERRIDE")
        fi
    fi

    # DISPLAY — the XWayland display (e.g. :0 or :1).  Required by Steam, Wine,
    # and any X11-only app.  The compositor starts XWayland and sets DISPLAY, but
    # may not have exported it to systemd yet when this function runs (race with
    # graphical-session.target).  Detect it from the process env (already imported
    # in apply_qt_runtime_env) or from the live X socket.
    if ! grep -q '^DISPLAY=' <<< "$sys_env" 2>/dev/null; then
        if [[ -n "${DISPLAY:-}" ]]; then
            vars_to_import+=("DISPLAY=$DISPLAY")
        else
            # Probe for XWayland socket — compositor may have started it but not
            # yet exported DISPLAY to systemd.
            local _xsock
            for _xsock in /tmp/.X11-unix/X*; do
                if [[ -S "$_xsock" ]]; then
                    local _xnum
                    _xnum="$(basename "$_xsock" | sed 's/^X//')"
                    vars_to_import+=("DISPLAY=:${_xnum}")
                    break
                fi
            done
        fi
    fi

    if [[ ${#vars_to_import[@]} -gt 0 ]]; then
        timeout 3s systemctl --user set-environment "${vars_to_import[@]}" 2>/dev/null || true
    fi
}

start_inir_service_if_enabled() {
    if is_inir_service_enabled; then
        ensure_service_unit_available
        ensure_systemd_graphical_env
        systemctl --user reset-failed inir.service >/dev/null 2>&1 || true
        systemctl --user start inir.service >/dev/null 2>&1 || true
        return 0
    fi

    return 1
}

start_background() {
    local dir="$1"
    if is_inir_service_enabled; then
        ensure_service_unit_available
        ensure_systemd_graphical_env
        systemctl --user reset-failed inir.service >/dev/null 2>&1 || true
        systemctl --user start inir.service >/dev/null 2>&1 || true
        return 0
    fi

    apply_hot_reload_policy_for_dir "$dir"
    nohup "$qs_bin" -n -d -p "$dir" >/dev/null 2>&1 &
}

kill_wrapper() {
    return 0
}

# Clean up stale Quickshell runtime entries and orphaned qs processes.
# Called by ExecStopPost in inir.service after crashes where KillMode=process
# only terminated the main PID, leaving child processes and runtime artifacts.
cleanup_orphans() {
    local qs_runtime_dir="/run/user/$(id -u)/quickshell"

    [[ -d "$qs_runtime_dir" ]] || return 0

    # Phase 1: Prune stale by-pid entries (PIDs that no longer exist).
    # by-pid/PID is a symlink to by-id/INSTANCE_ID.
    if [[ -d "$qs_runtime_dir/by-pid" ]]; then
        for pidfile in "$qs_runtime_dir/by-pid"/*; do
            [[ -e "$pidfile" || -L "$pidfile" ]] || continue
            local pid
            pid="$(basename "$pidfile")"
            if ! kill -0 "$pid" 2>/dev/null; then
                rm -rf "$pidfile" 2>/dev/null || true
            fi
        done
    fi

    # Phase 2: Prune orphaned by-id instance directories.
    # An instance dir is orphaned if no by-pid symlink points to it.
    if [[ -d "$qs_runtime_dir/by-id" ]]; then
        local live_targets=()
        # Collect targets of surviving by-pid symlinks
        for pidfile in "$qs_runtime_dir/by-pid"/*; do
            [[ -L "$pidfile" ]] || continue
            local target
            target="$(readlink -f "$pidfile" 2>/dev/null || true)"
            [[ -n "$target" ]] && live_targets+=("$target")
        done

        for iddir in "$qs_runtime_dir/by-id"/*/; do
            [[ -d "$iddir" ]] || continue
            local idpath
            idpath="$(realpath "$iddir" 2>/dev/null || true)"
            # Keep if referenced by a live by-pid symlink
            local is_live=false
            for t in "${live_targets[@]}"; do
                if [[ "$t" == "$idpath" ]]; then
                    is_live=true
                    break
                fi
            done
            if [[ "$is_live" == false ]]; then
                rm -rf "$iddir" 2>/dev/null || true
            fi
        done
    fi

    # Phase 3: Prune stale by-shell entries (dangling symlinks or empty dirs)
    if [[ -d "$qs_runtime_dir/by-shell" ]]; then
        for shelldir in "$qs_runtime_dir/by-shell"/*; do
            [[ -d "$shelldir" ]] || continue
            for entry in "$shelldir"/*; do
                [[ -e "$entry" || -L "$entry" ]] || continue
                # Remove dangling symlinks
                if [[ -L "$entry" && ! -e "$entry" ]]; then
                    rm -f "$entry" 2>/dev/null || true
                fi
            done
            # Remove shelldir if empty
            rmdir "$shelldir" 2>/dev/null || true
        done
    fi

    # Phase 4: Kill orphaned quickshell/qs processes not owned by the live service.
    # Only target qs processes, never user apps.
    local alive_pids
    alive_pids="$(pgrep -x 'quickshell|qs' 2>/dev/null || true)"
    if [[ -n "$alive_pids" ]]; then
        local service_main_pid=""
        service_main_pid="$(systemctl --user show -p MainPID inir.service 2>/dev/null | cut -d= -f2 || true)"

        while IFS= read -r pid; do
            [[ -n "$pid" ]] || continue
            # Skip the live service PID and its direct children
            if [[ -n "$service_main_pid" && "$service_main_pid" != "0" ]]; then
                [[ "$pid" == "$service_main_pid" ]] && continue
                local ppid
                ppid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
                [[ "$ppid" == "$service_main_pid" ]] && continue
            fi
            kill "$pid" 2>/dev/null || true
        done <<< "$alive_pids"
    fi
}

kill_shell() {
    local dir="$1"
    # Kill the wrapper first so it doesn't respawn qs after we kill it.
    kill_wrapper "$dir"
    # qs kill only kills one instance per invocation — loop until all are gone.
    local attempts=0
    while (( attempts < 10 )); do
        "$qs_bin" -p "$dir" kill >/dev/null 2>&1 || break
        attempts=$((attempts + 1))
        sleep 0.2
    done
    # Fallback: if qs kill didn't clean up, send SIGTERM to remaining qs processes.
    local remaining escaped_dir
    escaped_dir="$(printf '%s' "$dir" | sed 's/[.[\*^$()+|/]/\\&/g')"
    remaining="$(pgrep -f "${qs_bin}.*-p.*${escaped_dir}" 2>/dev/null || true)"
    if [[ -n "$remaining" ]]; then
        while IFS= read -r pid; do
            [[ -n "$pid" ]] || continue
            kill "$pid" >/dev/null 2>&1 || true
        done <<< "$remaining"
    fi
}

force_kill_qml_window() {
    local qml_path="$1"
    local pids

    pids="$(pgrep -f "${qs_bin} -n -p ${qml_path}" || true)"
    if [[ -z "$pids" ]]; then
        pids="$(pgrep -f "${qs_bin} .* -p ${qml_path}" || true)"
    fi

    if [[ -n "$pids" ]]; then
        while IFS= read -r pid; do
            [[ -n "$pid" ]] || continue
            kill "$pid" >/dev/null 2>&1 || true
        done <<< "$pids"
    fi
}

restart_shell() {
    local dir="$1"
    local quiet="${2:-}"

    if is_inir_service_enabled; then
        ensure_service_unit_available
        [[ -z "$quiet" ]] && printf 'Restarting iNiR service... '
        restart_inir_service_or_fail "$dir" "$quiet"
        return 0
    fi

    if has_instances "$dir"; then
        [[ -z "$quiet" ]] && printf 'Stopping iNiR... '
        kill_shell "$dir"
        if ! wait_for_stop "$dir"; then
            echo "Timed out waiting for iNiR to stop" >&2
            exit 1
        fi
        [[ -z "$quiet" ]] && printf 'done.\n'
    fi

    [[ -z "$quiet" ]] && printf 'Starting iNiR... '
    start_background "$dir"
    if ! wait_for_start "$dir"; then
        echo "Timed out waiting for iNiR to start" >&2
        exit 1
    fi
    [[ -z "$quiet" ]] && printf 'done.\n'

    if [[ -z "$quiet" ]]; then
        # Brief pause to let QML initialization settle before checking logs
        sleep 1
        local errors
        errors="$("$qs_bin" -p "$dir" log 2>/dev/null | grep -iE 'error|ReferenceError|TypeError|binding loop' | tail -10 || true)"
        if [[ -n "$errors" ]]; then
            printf '\n\033[33m── errors in recent logs ──\033[0m\n'
            printf '%s\n' "$errors"
        fi
    fi
}

open_settings() {
    local dir="$1"

    if ! ensure_running_instance "$dir"; then
        echo "Timed out waiting for iNiR to start" >&2
        exit 1
    fi

    exec "$qs_bin" -p "$dir" ipc call settings open
}

open_detached_qml_window() {
    local dir="$1"
    local entry="$2"
    local qml_path="$dir/$entry"

    if [[ ! -f "$qml_path" ]]; then
        echo "Could not find $entry in $dir" >&2
        exit 1
    fi

    # Serialize concurrent launches of the same entry point (e.g. rapid
    # keyboard-shortcut presses while the shell is unresponsive).  The lock
    # covers only the check-kill-launch window; it is released before exec
    # so child processes of qs (e.g. kde-material-you-colors) don't inherit
    # and leak it.
    local lock_file="${TMPDIR:-/tmp}/inir-launch-${entry%.qml}.lock"
    exec 9>"$lock_file"
    if ! flock -n 9; then
        echo "$entry launch already in progress" >&2
        exit 0
    fi

    if has_instances "$qml_path"; then
        kill_shell "$qml_path"
        if ! wait_for_stop "$qml_path"; then
            force_kill_qml_window "$qml_path"
            if ! wait_for_stop "$qml_path"; then
                echo "Timed out waiting for $entry to stop" >&2
                exit 1
            fi
        fi
    fi

    apply_qt_runtime_env
    apply_qt_logging_rules
    exec 9>&-
    exec "$qs_bin" -n -p "$qml_path"
}

resolve_setup_dir() {
    if [[ -x "$launcher_root/setup" && -f "$launcher_root/shell.qml" ]]; then
        printf '%s' "$launcher_root"
        return
    fi

    local version_file
    version_file="$(inir_version_file)"
    local stored_repo=""
    if [[ -f "$version_file" ]]; then
        if command -v jq >/dev/null 2>&1; then
            stored_repo=$(jq -r '.repoPath // .repo_path // empty' "$version_file" 2>/dev/null || true)
        else
            stored_repo=$(sed -n 's/.*"repoPath"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$version_file" | head -1)
            [[ -n "$stored_repo" ]] || stored_repo=$(sed -n 's/.*"repo_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$version_file" | head -1)
        fi
    fi

    stored_repo="${stored_repo/#\~/$HOME}"
    if [[ -n "$stored_repo" && -d "${stored_repo}/.git" && -x "${stored_repo}/setup" && -f "${stored_repo}/shell.qml" ]]; then
        printf '%s' "$stored_repo"
        return
    fi

    resolve_config_dir
    printf '%s' "$config_dir"
}

run_setup_command() {
    local dir="$1"
    shift
    local setup_script="$dir/setup"

    if [[ ! -x "$setup_script" ]]; then
        echo "setup not found in $dir" >&2
        exit 1
    fi

    cd "$dir"
    exec ./setup "$@"
}

run_setup_inline() {
    local dir="$1"
    shift
    local setup_script="$dir/setup"

    if [[ ! -x "$setup_script" ]]; then
        echo "setup not found in $dir" >&2
        exit 1
    fi

    (
        cd "$dir"
        ./setup "$@"
    )
}

resolve_launcher_path() {
    local candidate="${INIR_LAUNCHER_PATH:-}"
    if [[ -n "$candidate" ]]; then
        printf '%s' "$candidate"
        return
    fi

    candidate="$(command -v inir 2>/dev/null || true)"
    if [[ -n "$candidate" ]]; then
        printf '%s' "$candidate"
        return
    fi

    if command -v readlink >/dev/null 2>&1; then
        readlink -f "$0" 2>/dev/null || printf '%s' "$0"
    else
        printf '%s' "$0"
    fi
}

show_logs() {
    resolve_config_dir
    if [[ "${1:-}" == "--full" ]]; then
        "$qs_bin" -p "$config_dir" log
    else
        "$qs_bin" -p "$config_dir" log | tail -50
    fi
}

run_repair() {
    local dir="$1"

    printf '\n== running doctor ==\n'
    run_setup_inline "$dir" doctor

    if [[ -z "${WAYLAND_DISPLAY:-}" && -z "${DISPLAY:-}" && -z "${NIRI_SOCKET:-}" ]]; then
        printf '\n== no graphical session ==\n'
        printf 'doctor finished, but restart was skipped because there is no live display.\n'
        return
    fi

    printf '\n== restarting shell ==\n'
    kill_shell "$dir"
    sleep 1
    apply_shell_scale
    start_background "$dir"
    if ! wait_for_start "$dir"; then
        echo "Timed out waiting for iNiR to start during repair" >&2
        exit 1
    fi

    printf 'repair restart finished\n'
    printf '\n== recent logs ==\n'
    show_logs
    printf '\n== filtered errors ==\n'
    "$qs_bin" -p "$dir" log | grep -iE 'error|ReferenceError|TypeError|binding loop' | tail -80 || true
}

run_local_test() {
    local dir="$1"
    shift
    local test_script="$dir/scripts/test-local-distribution.sh"

    if [[ ! -x "$test_script" ]]; then
        echo "local test script not found in $dir" >&2
        exit 1
    fi

    INIR_RUNTIME_DIR="$dir" INIR_LAUNCHER_PATH="$0" exec "$test_script" "$@"
}

run_runtime_script() {
    local dir="$1"
    local relative_path="$2"
    shift 2
    local script_path="$dir/$relative_path"

    if [[ ! -x "$script_path" ]]; then
        echo "runtime script not found or not executable: $script_path" >&2
        exit 1
    fi

    exec "$script_path" "$@"
}

normalize_ipc_target() {
    # Try registry aliases first (comprehensive, auto-generated).
    if source_ipc_registry 2>/dev/null && [[ -n "${IPC_KEBAB_ALIASES[$1]+_}" ]]; then
        printf '%s\n' "${IPC_KEBAB_ALIASES[$1]}"
        return
    fi

    # Hardcoded fallback for when registry is unavailable.
    case "$1" in
        alt-switcher) printf '%s\n' "altSwitcher" ;;
        close-confirm) printf '%s\n' "closeConfirm" ;;
        control-panel) printf '%s\n' "controlPanel" ;;
        media-controls) printf '%s\n' "mediaControls" ;;
        osd-volume) printf '%s\n' "osdVolume" ;;
        panel-family) printf '%s\n' "panelFamily" ;;
        shell-update) printf '%s\n' "shellUpdate" ;;
        sidebar-left) printf '%s\n' "sidebarLeft" ;;
        sidebar-right) printf '%s\n' "sidebarRight" ;;
        voice-search) printf '%s\n' "voiceSearch" ;;
        wallpaper-selector) printf '%s\n' "wallpaperSelector" ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

# --- IPC target help and validation (Steps 5-7) ---

ipc_target_help() {
    local target="$1"

    if ! source_ipc_registry 2>/dev/null; then
        printf '%s — no registry available. See docs/IPC.md.\n' "$target" >&2
        return 1
    fi

    if [[ -z "${IPC_TARGET_FUNCTIONS[$target]+_}" ]]; then
        return 1
    fi

    local desc="${IPC_TARGET_DESC[$target]:-}"
    local family="${IPC_TARGET_FAMILY[$target]:-shared}"
    local funcs_str="${IPC_TARGET_FUNCTIONS[$target]:-}"
    local example="${IPC_TARGET_EXAMPLE[$target]:-}"

    # Header
    if [[ -n "$desc" ]]; then
        printf '%s — %s\n' "$target" "$desc"
    else
        printf '%s\n' "$target"
    fi
    printf '\n'

    # Functions
    if [[ -n "$funcs_str" ]]; then
        printf 'Available functions:\n'
        local fn
        for fn in $funcs_str; do
            local fn_desc="${IPC_FUNCTION_DESC["$target:$fn"]:-}"
            local fn_args="${IPC_FUNCTION_ARGS["$target:$fn"]:-}"
            local display_name="$fn"
            if [[ -n "$fn_args" ]]; then
                display_name="$fn $fn_args"
            fi
            if [[ -n "$fn_desc" ]]; then
                printf '  %-28s %s\n' "$display_name" "$fn_desc"
            else
                printf '  %s\n' "$display_name"
            fi
        done
        printf '\n'
    fi

    # Family
    case "$family" in
        shared) printf 'Family: shared (works with both ii and waffle)\n' ;;
        ii)     printf 'Family: ii panel family only\n' ;;
        waffle) printf 'Family: waffle panel family only\n' ;;
    esac

    # Example keybind
    if [[ -n "$example" ]]; then
        printf '\nExample keybind:\n'
        local line
        while IFS= read -r line; do
            printf '  %s\n' "$line"
        done <<< "$example"
    fi
}

suggest_ipc_target() {
    local input="$1"

    if ! source_ipc_registry 2>/dev/null; then
        return 1
    fi

    local suggestions=()
    local t

    # 1. Exact kebab alias match (already handled by normalize, but just in case)
    if [[ -n "${IPC_KEBAB_ALIASES[$input]+_}" ]]; then
        suggestions+=("${IPC_KEBAB_ALIASES[$input]}")
    fi

    # 2. Substring match
    for t in "${IPC_ALL_TARGETS[@]}"; do
        if [[ "$t" == *"$input"* || "${t,,}" == *"${input,,}"* ]]; then
            local already=false
            local s
            for s in "${suggestions[@]+"${suggestions[@]}"}"; do
                if [[ "$s" == "$t" ]]; then already=true; break; fi
            done
            if [[ "$already" == false ]]; then
                suggestions+=("$t")
            fi
        fi
    done

    # 3. Prefix match (first 3+ chars)
    if [[ ${#input} -ge 3 ]]; then
        local prefix="${input:0:3}"
        for t in "${IPC_ALL_TARGETS[@]}"; do
            if [[ "${t:0:3}" == "$prefix" || "${t,,}" == "${prefix,,}"* ]]; then
                local already=false
                local s
                for s in "${suggestions[@]+"${suggestions[@]}"}"; do
                    if [[ "$s" == "$t" ]]; then already=true; break; fi
                done
                if [[ "$already" == false ]]; then
                    suggestions+=("$t")
                fi
            fi
        done
    fi

    if [[ ${#suggestions[@]} -eq 0 ]]; then
        return 1
    fi

    printf 'Did you mean?\n'
    for t in "${suggestions[@]}"; do
        local desc="${IPC_TARGET_DESC[$t]:-}"
        desc="${desc%%.*}"
        if [[ -n "$desc" ]]; then
            printf '  %-24s %s\n' "$t" "$desc"
        else
            printf '  %s\n' "$t"
        fi
    done
    return 0
}

validate_ipc_function() {
    local target="$1"
    local func="$2"

    # Only validate if registry is available and target is known.
    # Unknown targets pass through for plugin extensibility.
    if ! source_ipc_registry 2>/dev/null; then
        return 0
    fi

    if [[ -z "${IPC_TARGET_FUNCTIONS[$target]+_}" ]]; then
        # Target not in registry — could be a plugin target, pass through.
        return 0
    fi

    local funcs_str="${IPC_TARGET_FUNCTIONS[$target]}"
    local fn
    for fn in $funcs_str; do
        if [[ "$fn" == "$func" ]]; then
            return 0
        fi
    done

    # Function not found — show available functions
    printf "Unknown function '%s' for target '%s'.\n\n" "$func" "$target" >&2
    ipc_target_help "$target" >&2
    exit 1
}

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "$1 not found" >&2
        exit 1
    fi
}

is_inir_service_active() {
    if ! command -v systemctl >/dev/null 2>&1; then
        return 1
    fi

    systemctl --user is-active --quiet inir.service >/dev/null 2>&1
}

is_current_process_inir_service() {
    grep -q '/inir\.service' "/proc/$$/cgroup" 2>/dev/null
}

stop_inir_service_if_active() {
    if is_inir_service_active; then
        systemctl --user stop inir.service >/dev/null 2>&1 || true
        return 0
    fi

    return 1
}

restart_inir_service_if_active() {
    # Only check — actual restart is done by restart_inir_service_or_fail.
    is_inir_service_active
}

report_inir_service_failure() {
    local lines="${1:-20}"

    if ! command -v systemctl >/dev/null 2>&1; then
        return 1
    fi

    printf '\n\033[31m── inir.service status ──\033[0m\n' >&2
    systemctl --user status inir.service --no-pager 2>&1 | sed -n '1,18p' >&2 || true

    if command -v journalctl >/dev/null 2>&1; then
        printf '\n\033[31m── recent inir.service logs ──\033[0m\n' >&2
        journalctl --user-unit inir.service -n "$lines" --no-pager 2>&1 >&2 || true
    fi

    return 0
}

restart_inir_service_or_fail() {
    local dir="$1"
    local quiet="${2:-}"

    ensure_service_unit_available
    ensure_systemd_graphical_env
    systemctl --user reset-failed inir.service >/dev/null 2>&1 || true
    systemctl --user restart inir.service >/dev/null 2>&1 || true

    if ! wait_for_start "$dir"; then
        echo "Timed out waiting for iNiR to start" >&2
        report_inir_service_failure
        exit 1
    fi

    if ! systemctl --user is-active --quiet inir.service >/dev/null 2>&1; then
        echo "iNiR service failed to start" >&2
        report_inir_service_failure
        exit 1
    fi

    [[ -z "$quiet" ]] && printf 'done.\n'
    return 0
}

install_user_service() {
    local setup_dir
    local asset_path
    local launcher_path
    local tmp_file

    require_command systemctl
    setup_dir="$(resolve_setup_dir)"
    asset_path="$setup_dir/assets/systemd/inir.service"
    launcher_path="$(resolve_launcher_path)"

    if [[ ! -f "$asset_path" ]]; then
        echo "service asset not found in $setup_dir" >&2
        exit 1
    fi

    mkdir -p "$systemd_user_dir"
    mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}"
    tmp_file="${XDG_CACHE_HOME:-$HOME/.cache}/inir.service.$$"
    local escaped_launcher="${launcher_path//&/\\&}"
    sed -e "s|^ExecStart=.*|ExecStart=${escaped_launcher} run --session|" \
        -e "s|^ExecStopPost=-.*|ExecStopPost=-${escaped_launcher} cleanup-orphans|" \
        "$asset_path" > "$tmp_file"
    cp -f "$tmp_file" "$systemd_user_dir/inir.service"
    rm -f "$tmp_file"

    # Migrate: remove old WantedBy=graphical-session.target symlink left by
    # previous versions that used [Install] + systemctl enable.  This is the
    # link that caused inir to spawn under KDE/GNOME.
    cleanup_stale_wants_links

    systemctl --user daemon-reload
    printf '%s\n' "$systemd_user_dir/inir.service"
}

cleanup_stale_wants_links() {
    # Remove inir.service wants links from targets it should NOT be wired to.
    # Previous versions used WantedBy=graphical-session.target which caused
    # inir to start under any DE.  Remove that, and only keep the link if it
    # lives under the detected compositor service.
    local correct_target
    correct_target="$(detect_compositor_service 2>/dev/null)" || correct_target=""
    local correct_wants_dir=""
    [[ -n "$correct_target" ]] && correct_wants_dir="$systemd_user_dir/${correct_target}.wants"

    local wants_dir
    for wants_dir in "$systemd_user_dir"/*.wants; do
        [[ -d "$wants_dir" ]] || continue
        local link="$wants_dir/inir.service"
        [[ -e "$link" || -L "$link" ]] || continue
        # Keep the link if it's under the correct compositor
        if [[ -n "$correct_wants_dir" ]] && \
           [[ "$(realpath "$wants_dir" 2>/dev/null)" == "$(realpath "$correct_wants_dir" 2>/dev/null)" ]]; then
            continue
        fi
        rm -f "$link"
    done
}

enable_inir_service() {
    # Wire inir.service to the compositor's wants directory so it starts
    # only when that specific compositor starts — not under KDE/GNOME/etc.
    require_command systemctl
    ensure_service_unit_available

    local target
    target="$(detect_compositor_service 2>/dev/null)" || true

    if [[ -z "$target" ]]; then
        echo "ERROR: No supported compositor detected (niri or Hyprland)." >&2
        echo "       Install a supported compositor first, then re-run 'inir service enable'." >&2
        return 1
    fi

    local wants_dir="$systemd_user_dir/${target}.wants"

    mkdir -p "$wants_dir"
    ln -sf "$systemd_user_dir/inir.service" "$wants_dir/inir.service"
    systemctl --user daemon-reload

    printf 'Enabled inir.service (wired to %s)\n' "$target"
}

disable_inir_service() {
    # Remove all wants links for inir.service and stop the service.
    require_command systemctl

    systemctl --user stop inir.service 2>/dev/null || true

    local found=false
    local wants_dir
    for wants_dir in "$systemd_user_dir"/*.wants; do
        [[ -d "$wants_dir" ]] || continue
        local link="$wants_dir/inir.service"
        if [[ -e "$link" || -L "$link" ]]; then
            rm -f "$link"
            found=true
        fi
    done

    systemctl --user daemon-reload

    if [[ "$found" == true ]]; then
        echo "Disabled inir.service"
    else
        echo "inir.service was not enabled"
    fi
}

ensure_service_unit_available() {
    # Always reinstall the service template to pick up improvements (e.g. KillMode,
    # rate limits). install_user_service is cheap — just a sed + cp + daemon-reload.
    install_user_service >/dev/null

    # Warn if effective KillMode isn't process — child apps (e.g. mpv) would be
    # killed on shell restart until the user runs 'inir service install'.
    local effective_killmode
    effective_killmode=$(systemctl --user show -p KillMode inir.service 2>/dev/null | cut -d= -f2)
    if [ -n "$effective_killmode" ] && [ "$effective_killmode" != "process" ]; then
        echo "WARNING: inir.service KillMode is '$effective_killmode' (expected 'process') — run 'inir service install' to fix" >&2
    fi
}

run_service_command() {
    local action="${1:-status}"
    shift || true

    case "$action" in
        install)
            install_user_service
            ;;
        uninstall|remove)
            disable_inir_service 2>/dev/null || true
            require_command systemctl
            rm -f "$systemd_user_dir/inir.service"
            systemctl --user daemon-reload
            echo "Uninstalled inir.service"
            ;;
        enable)
            enable_inir_service
            ;;
        disable)
            disable_inir_service
            ;;
        start)
            ensure_service_unit_available
            exec systemctl --user start inir.service
            ;;
        stop)
            exec systemctl --user stop inir.service
            ;;
        restart)
            ensure_service_unit_available
            exec systemctl --user restart inir.service
            ;;
        status)
            exec systemctl --user status inir.service "$@"
            ;;
        logs)
            require_command journalctl
            exec journalctl --user-unit inir.service "$@"
            ;;
        -h|--help|"")
            service_usage
            exit 0
            ;;
        *)
            echo "Unknown service action: $action" >&2
            exit 1
            ;;
    esac
}

show_version() {
    local json=false
    local runtime_path=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json=true
                shift
                ;;
            -h|--help)
                echo "Usage: inir version [--json]" >&2
                exit 0
                ;;
            *)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
        esac
    done

    # Prefer running instance path for accurate version display
    local running
    if running="$(detect_running_instance_dir)"; then
        runtime_path="$(canonicalize_path "$running")"
    else
        local candidate
        for candidate in "$config_dir" "$user_config_dir" "$system_config_dir" "$fallback_system_config_dir"; do
            if [[ -n "$candidate" && -f "$candidate/shell.qml" ]]; then
                runtime_path="$candidate"
                break
            fi
        done
    fi

    local runtime_version_file=""
    local local_version_file
    local_version_file="$(inir_version_file)"
    local version_file=""

    if [[ -n "$runtime_path" ]]; then
        runtime_version_file="$runtime_path/version.json"
    fi

    local runtime_install_mode=""
    if [[ -n "$runtime_version_file" && -f "$runtime_version_file" ]] && command -v jq >/dev/null 2>&1; then
        runtime_install_mode="$(jq -r '.installMode // .install_mode // empty' "$runtime_version_file" 2>/dev/null || true)"
    fi

    if [[ -n "${INIR_RUNTIME_DIR:-}" && -n "$runtime_version_file" && -f "$runtime_version_file" ]]; then
        version_file="$runtime_version_file"
    elif [[ "$runtime_install_mode" == "package-managed" ]]; then
        version_file="$runtime_version_file"
    elif [[ -f "$local_version_file" ]]; then
        version_file="$local_version_file"
    elif [[ -n "$runtime_version_file" && -f "$runtime_version_file" ]]; then
        version_file="$runtime_version_file"
    fi

    local live_repo=""
    live_repo="$(resolve_live_version_context "$version_file" "$runtime_path" || true)"

    if [[ -n "$live_repo" ]]; then
        local live_version live_commit live_branch
        live_version="$(tr -d '[:space:]' < "$live_repo/VERSION" 2>/dev/null || echo unknown)"
        live_commit="$(git -C "$live_repo" rev-parse --short HEAD 2>/dev/null || echo unknown)"
        live_branch="$(git -C "$live_repo" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"

        if [[ "$json" == true ]]; then
            printf '{\n'
            printf '  "version": "%s",\n' "$live_version"
            printf '  "commit": "%s",\n' "$live_commit"
            printf '  "installMode": "repo-link",\n'
            printf '  "updateStrategy": "repo-setup",\n'
            printf '  "runtime": "%s",\n' "${runtime_path:-$live_repo}"
            printf '  "repoPath": "%s",\n' "$live_repo"
            printf '  "branch": "%s"\n' "${live_branch:-unknown}"
            printf '}\n'
            return
        fi

        printf 'iNiR %s\n' "$live_version"
        printf 'commit: %s\n' "$live_commit"
        printf 'install mode: repo-link\n'
        printf 'update strategy: repo-setup\n'
        printf 'source: live checkout\n'
        printf 'runtime: %s\n' "${runtime_path:-$live_repo}"
        printf 'repo: %s\n' "$live_repo"
        if [[ -n "$live_branch" ]]; then
            printf 'branch: %s\n' "$live_branch"
            if [[ "$live_branch" != "main" && "$live_branch" != "master" ]]; then
                printf 'note: non-release branch\n'
            fi
        fi
        return
    fi

    if [[ -n "$version_file" && -f "$version_file" ]]; then
        if [[ "$json" == true ]]; then
            cat "$version_file"
            return
        fi

        if command -v jq >/dev/null 2>&1; then
            printf 'iNiR %s\n' "$(jq -r '.version // "unknown"' "$version_file")"
            printf 'commit: %s\n' "$(jq -r '.commit // "unknown"' "$version_file")"
            printf 'install mode: %s\n' "$(jq -r '.installMode // .install_mode // "unknown"' "$version_file")"
            printf 'update strategy: %s\n' "$(jq -r '.updateStrategy // .update_strategy // "unknown"' "$version_file")"
            printf 'source: %s\n' "$(jq -r '.source // "unknown"' "$version_file")"
            printf 'runtime: %s\n' "$runtime_path"
            # Show git branch if in a repo
            local repo_dir=""
            repo_dir="$(jq -r '.repoPath // empty' "$version_file" 2>/dev/null || true)"
            [[ -z "$repo_dir" ]] && repo_dir="$runtime_path"
            if [[ -n "$repo_dir" && -d "$repo_dir/.git" ]]; then
                local git_branch
                git_branch="$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
                if [[ -n "$git_branch" ]]; then
                    printf 'branch: %s\n' "$git_branch"
                    if [[ "$git_branch" != "main" && "$git_branch" != "master" ]]; then
                        printf 'note: non-release branch\n'
                    fi
                fi
            fi
            return
        fi
    fi

    local setup_dir
    setup_dir="$(resolve_setup_dir)"
    if [[ "$json" == true ]]; then
        printf '{\n  "version": "%s",\n  "runtime": "%s"\n}\n' "$(tr -d '[:space:]' < "$setup_dir/VERSION")" "${runtime_path:-$setup_dir}"
        return
    fi

    printf 'iNiR %s\n' "$(tr -d '[:space:]' < "$setup_dir/VERSION")"
    printf 'runtime: %s\n' "${runtime_path:-$setup_dir}"
}

run_theme_command() {
    local action="${1:-}"
    shift || true

    local setup_dir
    setup_dir="$(resolve_setup_dir)"
    local colors_dir="$setup_dir/scripts/colors"

    case "$action" in
        list-targets)
            exec python3 "$colors_dir/list-targets.py" list "$@"
            ;;
        inspect)
            if [[ $# -lt 1 ]]; then
                echo "Usage: inir theme inspect <target-id>" >&2
                exit 1
            fi
            exec python3 "$colors_dir/list-targets.py" inspect "$@"
            ;;
        doctor)
            exec python3 "$colors_dir/list-targets.py" doctor "$@"
            ;;
        scaffold)
            if [[ $# -lt 1 ]]; then
                echo "Usage: inir theme scaffold <target-id> [--label ... --category ... --inputs ...]" >&2
                exit 1
            fi
            exec python3 "$colors_dir/list-targets.py" scaffold "$@"
            ;;
        apply)
            if [[ $# -eq 0 ]]; then
                echo "Usage: inir theme apply <target-id ...|all>" >&2
                exit 1
            fi
            exec bash "$colors_dir/apply-targets.sh" "$@"
            ;;
        -h|--help|"")
            cat <<'EOF' >&2
Usage: inir theme <command> [args...]

Commands:
  list-targets          List declared theming targets
  inspect <id>          Show manifest, module, and resolved input info for a target
  doctor [id]           Validate all targets, or a specific one
  scaffold <id>         Create a new target manifest and module stub
  apply <ids...|all>    Apply one or more theming targets
EOF
            exit 0
            ;;
        *)
            echo "Unknown theme action: $action" >&2
            exit 1
            ;;
    esac
}

run_ipc_target_command() {
    local target
    target="$(normalize_ipc_target "$1")"
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -c|--config)
                parse_config_flag "$@"
                shift 2
                ;;
            --)
                shift
                break
                ;;
            -h|--help)
                if ipc_target_help "$target"; then
                    exit 0
                fi
                echo "Usage: inir $target [-c PATH] <function> [args...]" >&2
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $# -lt 1 ]]; then
        # No function given — show target help instead of bare error.
        if ipc_target_help "$target" 2>/dev/null; then
            exit 1
        fi
        echo "Usage: inir $target <function> [args...]" >&2
        exit 1
    fi

    # Validate function name against registry before forwarding to qs.
    validate_ipc_function "$target" "$1"

    resolve_config_dir
    if ! ensure_running_instance_for_ipc "$config_dir" "${1:-}"; then
        echo "Timed out waiting for iNiR to start" >&2
        exit 1
    fi
    # IPC handlers for most panels register ~500ms after shell start (deferred panel
    # loading at boot). If the first call fails while the shell is still initializing,
    # retry once after a brief wait before giving up.
    if ! "$qs_bin" -p "$config_dir" ipc call "$target" "$@" 2>/dev/null; then
        has_instances "$config_dir" && sleep 0.5
        exec "$qs_bin" -p "$config_dir" ipc call "$target" "$@"
    fi
}

launch_configured_browser() {
    local config_file
    config_file="$(inir_config_file)"
    local browser=""

    if [[ -f "$config_file" ]]; then
        if command -v jq >/dev/null 2>&1; then
            browser="$(jq -r '.apps.browser // empty' "$config_file" 2>/dev/null || true)"
        else
            browser="$(sed -n 's/.*"browser"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$config_file" | head -1)"
        fi
    fi

    browser="${browser:-xdg-open}"

    if command -v "$browser" >/dev/null 2>&1; then
        if [[ $# -gt 0 ]]; then
            exec "$browser" "$@"
        fi
        exec "$browser"
    fi

    if command -v xdg-open >/dev/null 2>&1; then
        if [[ $# -gt 0 ]]; then
            exec xdg-open "$@"
        fi
        exec xdg-open "https://"
    fi

    echo "No browser launcher found" >&2
    exit 1
}

parse_config_flag() {
    if [[ $# -lt 2 ]]; then
        echo "Missing path after $1" >&2
        exit 1
    fi
    config_dir="$2"
}

command_name="${1:-help}"
shift || true

case "$command_name" in
    install)
        setup_dir="$(resolve_setup_dir)"
        run_setup_command "$setup_dir" install "$@"
        ;;
    start)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    repair_usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        apply_shell_scale
        apply_qt_runtime_env
        check_qs_abi
        check_setup_version_sync "$config_dir"
        if has_instances "$config_dir"; then
            echo "iNiR is already running. Use 'inir restart' to restart." >&2
            exit 0
        fi
        start_background "$config_dir"
        ;;
    stop)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        stop_inir_service_if_active
        kill_shell "$config_dir"
        ;;
    run)
        require_qs
        foreground=true
        _session_boot=false
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                --daemon)
                    foreground=false
                    shift
                    ;;
                --foreground)
                    foreground=true
                    shift
                    ;;
                --session)
                    foreground=true
                    _session_boot=true
                    shift
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done

        if [[ "$_session_boot" == true ]]; then
            # ── Session boot fast path ──
            # The service unit pre-seeds QT_SCALE_FACTOR and QT_LOGGING_RULES, so
            # apply_shell_scale / apply_qt_logging_rules are no-ops here.
            # Systemd manages lifecycle (Restart=on-failure) and I/O priority.
            _skip_running_detect=true
            resolve_config_dir
            apply_hot_reload_policy_for_dir "$config_dir"
            check_qs_abi
            wait_for_wayland_socket       # block until compositor socket exists
            apply_qt_runtime_env          # WAYLAND_DISPLAY + platformtheme fallback
            ensure_systemd_graphical_env & # export env to systemd for other services
            exec "$qs_bin" -n -p "$config_dir"
        fi

        # ── Normal run path (manual invocation) ──
        resolve_config_dir
        apply_hot_reload_policy_for_dir "$config_dir"
        apply_shell_scale
        apply_qt_runtime_env
        apply_qt_logging_rules
        ensure_systemd_graphical_env &  # env already cached by apply_qt_runtime_env
        check_qs_abi
        check_setup_version_sync "$config_dir"
        if has_instances "$config_dir"; then
            echo "iNiR is already running. Use 'inir restart' to restart." >&2
            exit 0
        fi
        if [[ "$foreground" == true ]] && is_inir_service_active; then
            if ! is_current_process_inir_service; then
                echo "iNiR is managed by inir.service. Stop it first before running manually." >&2
                exit 1
            fi
        fi
        if [[ "$foreground" == true ]]; then
            exec "$qs_bin" -n -p "$config_dir"
        fi
        if is_inir_service_enabled; then
            ensure_service_unit_available
            start_inir_service_if_enabled
            exit 0
        fi
        exec "$qs_bin" -n -d -p "$config_dir"
        ;;
    restart)
        require_qs
        restart_quiet=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -q|--quiet)
                    restart_quiet="1"
                    shift
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        apply_shell_scale
        apply_qt_runtime_env
        apply_qt_logging_rules
        check_qs_abi
        if restart_inir_service_if_active; then
            [[ -z "$restart_quiet" ]] && printf 'Restarting iNiR service... '
            restart_inir_service_or_fail "$config_dir" "$restart_quiet"
            exit 0
        fi
        restart_shell "$config_dir" "$restart_quiet"
        ;;
    kill)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        stop_inir_service_if_active
        kill_shell "$config_dir"
        ;;
    logs)
        require_qs
        if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
            usage
            exit 0
        fi
        show_logs "${1:-}"
        ;;
    terminal)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                --)
                    shift
                    break
                    ;;
                -h|--help)
                    echo "Usage: inir terminal [-c PATH] [args...]" >&2
                    exit 0
                    ;;
                *)
                    break
                    ;;
            esac
        done
        resolve_config_dir
        run_runtime_script "$config_dir" "scripts/launch-terminal.sh" "$@"
        ;;
    browser)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                --)
                    shift
                    break
                    ;;
                -h|--help)
                    echo "Usage: inir browser [-c PATH] [url]" >&2
                    exit 0
                    ;;
                *)
                    break
                    ;;
            esac
        done
        launch_configured_browser "$@"
        ;;
    close-window)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    echo "Usage: inir close-window [-c PATH]" >&2
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        run_runtime_script "$config_dir" "scripts/close-window.sh"
        ;;
    colorpicker)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -h|--help)
                    echo "Usage: inir colorpicker" >&2
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        if ! command -v hyprpicker >/dev/null 2>&1; then
            echo "hyprpicker not found — install it to use colorpicker" >&2
            exit 1
        fi
        exec /usr/bin/hyprpicker -a
        ;;
    ipc)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                --)
                    shift
                    break
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    break
                    ;;
            esac
        done
        if [[ $# -lt 2 ]]; then
            echo "Usage: inir ipc <target> <function> [args...]" >&2
            exit 1
        fi
        resolve_config_dir
        if ! ensure_running_instance_for_ipc "$config_dir" "${2:-}"; then
            echo "Timed out waiting for iNiR to start" >&2
            exit 1
        fi
        if ! "$qs_bin" -p "$config_dir" ipc call "$@" 2>/dev/null; then
            has_instances "$config_dir" && sleep 0.5
            exec "$qs_bin" -p "$config_dir" ipc call "$@"
        fi
        ;;
    settings|open)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        open_settings "$config_dir"
        ;;
    settings-window)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        open_detached_qml_window "$config_dir" "settings.qml"
        ;;
    waffle-settings-window)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        open_detached_qml_window "$config_dir" "waffleSettings.qml"
        ;;
    welcome)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        open_detached_qml_window "$config_dir" "welcome.qml"
        ;;
    repair)
        require_qs
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    repair_usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        run_repair "$config_dir"
        ;;
    path)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    echo "Unknown option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        resolve_config_dir
        printf '%s\n' "$config_dir"
        ;;
    test-local)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                --with-runtime)
                    break
                    ;;
                -h|--help)
                    usage
                    exit 0
                    ;;
                *)
                    break
                    ;;
            esac
        done
        setup_dir="$(resolve_setup_dir)"
        run_local_test "$setup_dir" "$@"
        ;;
    setup)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                *)
                    break
                    ;;
            esac
        done
        setup_dir="$(resolve_setup_dir)"
        run_setup_command "$setup_dir" "$@"
        ;;
    service)
        run_service_command "$@"
        ;;
    cleanup-orphans)
        cleanup_orphans
        ;;
    doctor)
        # Quick path: `inir doctor --fix-abi` rebuilds quickshell directly without
        # running the full 22-step pipeline. Useful for pacman hooks and scripts.
        fix_abi_only=false
        fix_abi_mode=interactive
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --fix-abi)
                    fix_abi_only=true
                    shift
                    ;;
                -n|--noninteractive|--non-interactive|-y|--yes)
                    fix_abi_mode=noninteractive
                    shift
                    ;;
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                *)
                    break
                    ;;
            esac
        done
        if $fix_abi_only; then
            require_qs
            _inir_run_quickshell_rebuild "$fix_abi_mode"
            exit $?
        fi
        setup_dir="$(resolve_setup_dir)"
        run_setup_command "$setup_dir" "$command_name" "$@"
        ;;
    migrate|status|update|reinstall|rollback|my-changes|uninstall|config|info|backup|logs)
        while [[ $# -gt 0 ]]; do
            case "$1" in
                -c|--config)
                    parse_config_flag "$@"
                    shift 2
                    ;;
                *)
                    break
                    ;;
            esac
        done
        setup_dir="$(resolve_setup_dir)"
        run_setup_command "$setup_dir" "$command_name" "$@"
        ;;
    version)
        show_version "$@"
        ;;
    theme)
        run_theme_command "$@"
        ;;
    completions)
        _comp_shell="${1:-}"
        case "$_comp_shell" in
            bash|zsh|fish)
                _comp_candidates=(
                    "$script_dir/completions/inir.${_comp_shell}"
                    "$launcher_root/share/quickshell/inir/scripts/completions/inir.${_comp_shell}"
                    "$user_config_dir/scripts/completions/inir.${_comp_shell}"
                    "$system_config_dir/scripts/completions/inir.${_comp_shell}"
                    "$fallback_system_config_dir/scripts/completions/inir.${_comp_shell}"
                )
                _comp_file=""
                for _cand in "${_comp_candidates[@]}"; do
                    if [[ -f "$_cand" ]]; then
                        _comp_file="$_cand"
                        break
                    fi
                done
                if [[ -n "$_comp_file" ]]; then
                    cat "$_comp_file"
                else
                    printf "Error: %s completion file not found. Searched:\n" "$_comp_shell" >&2
                    for _cand in "${_comp_candidates[@]}"; do
                        printf "  %s\n" "$_cand" >&2
                    done
                    exit 1
                fi
                ;;
            "")
                printf "Usage: inir completions <bash|zsh|fish>\n\n"
                printf "Print shell completion script to stdout.\n\n"
                printf "Examples:\n"
                printf "  eval \"\$(inir completions bash)\"     # Add to .bashrc\n"
                printf "  inir completions zsh > ~/.zsh/completions/_inir\n"
                printf "  inir completions fish | source        # Add to config.fish\n"
                ;;
            *)
                printf "Unknown shell: '%s'. Supported: bash, zsh, fish\n" "$_comp_shell" >&2
                exit 1
                ;;
        esac
        ;;
    help|-h|--help|"")
        usage_short
        printf '\n'
        usage
        ;;
    *)
        # Pre-validate: if registry is available and target is completely unknown,
        # show suggestions before forwarding to Quickshell's bare "Target not found."
        normalized="$(normalize_ipc_target "$command_name")"

        if source_ipc_registry 2>/dev/null; then
            # Check if target is known in registry
            if [[ -z "${IPC_TARGET_FUNCTIONS[$normalized]+_}" ]]; then
                # Unknown target — try to suggest similar ones
                printf "Unknown command: '%s'\n\n" "$command_name" >&2
                if ! suggest_ipc_target "$normalized" >&2; then
                    printf "Run 'inir help' for all commands.\n" >&2
                else
                    printf "\nRun 'inir help' for all commands.\n" >&2
                fi
                exit 1
            fi
        fi

        require_qs
        run_ipc_target_command "$command_name" "$@"
        ;;
esac
